# Canary quickstart configuration
#
# Copy this file to ".env" in the docker directory before running Docker Compose.
# The public contract for Canary Docker settings is the CANARY_* prefix.

# Database used by Canary, MyAAC, and login-server.
CANARY_DB_HOST=db
CANARY_DB_PORT=3306
CANARY_DB_NAME=canary
CANARY_DB_USER=canary
CANARY_DB_PASSWORD=canary
CANARY_DB_ROOT_PASSWORD=root

# Address advertised to clients in the character/world list.
# For local quickstart, 127.0.0.1 points the client back to the host machine.
CANARY_SERVER_NAME=OpenTibiaBR Canary
CANARY_SERVER_IP=127.0.0.1
CANARY_SERVER_LOCATION=BRA

# Canary runtime image and ports published by the quickstart.
# The "latest" tag is rolling. Pin CANARY_IMAGE when reproducibility matters.
CANARY_IMAGE=ghcr.io/opentibiabr/canary:latest
CANARY_LOGIN_PORT=7171
CANARY_GAME_PORT=7172
CANARY_STATUS_PORT=7173
CANARY_STATUS_TIMEOUT=5000

# Seed and data pack options.
CANARY_TEST_ACCOUNTS=true
CANARY_DATA_PACK=data-otservbr-global
CANARY_MAP_URL=https://github.com/opentibiabr/canary/releases/download/v3.6.0/otservbr.otbm

# MyAAC site. The Dockerfile builds from the MyAAC develop branch by default.
MYAAC_HTTP_PORT=8080
MYAAC_SITE_URL=http://localhost:8080
MYAAC_REF=develop
MYAAC_ADMIN_ACCOUNT=myaacadmin
MYAAC_ADMIN_EMAIL=admin@localhost.local
MYAAC_ADMIN_PASSWORD=admin123
MYAAC_ADMIN_PLAYER=ADM1
MYAAC_CLIENT_VERSION=1511
MYAAC_TIMEZONE=America/Fortaleza

# Login-server image, ports, and rate limits used by the client login webservice.
# The "latest" tag is rolling. Pin LOGIN_SERVER_IMAGE when reproducibility matters.
LOGIN_SERVER_IMAGE=opentibiabr/login-server:latest
LOGIN_HTTP_PORT=8088
LOGIN_GRPC_PORT=9090
LOGIN_RATE_LIMITER_RATE=2
LOGIN_RATE_LIMITER_BURST=5
