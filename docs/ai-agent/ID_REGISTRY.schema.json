{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://canary.local/schemas/ai-agent/id-registry.schema.json",
  "title": "Canary AI Agent Identifier Registry",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "baseCommit", "namespaces", "conflicts"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "baseCommit": { "type": "string", "minLength": 7 },
    "namespaces": {
      "type": "object",
      "required": ["storage", "actionId", "uniqueId", "itemId"],
      "properties": {
        "storage": { "$ref": "#/$defs/namespace" },
        "actionId": { "$ref": "#/$defs/namespace" },
        "uniqueId": { "$ref": "#/$defs/namespace" },
        "itemId": { "$ref": "#/$defs/namespace" }
      },
      "additionalProperties": false
    },
    "conflicts": {
      "type": "array",
      "items": { "$ref": "#/$defs/conflict" }
    },
    "reservations": {
      "type": "array",
      "items": { "$ref": "#/$defs/reservation" },
      "default": []
    },
    "binarySources": {
      "type": "array",
      "items": { "$ref": "#/$defs/binarySource" },
      "default": []
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "required": ["path", "role"],
      "properties": {
        "path": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "symbol": { "type": "string" },
        "context": { "type": "string" },
        "role": { "enum": ["definition", "reference"] }
      },
      "additionalProperties": false
    },
    "entry": {
      "type": "object",
      "required": ["value", "sources"],
      "properties": {
        "value": { "type": "integer", "minimum": 0 },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/source" }
        }
      },
      "additionalProperties": false
    },
    "namespace": {
      "type": "object",
      "required": ["entries"],
      "properties": {
        "entries": {
          "type": "array",
          "items": { "$ref": "#/$defs/entry" }
        },
        "minimum": { "type": "integer" },
        "maximum": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "conflict": {
      "type": "object",
      "required": ["namespace", "value", "sources", "severity"],
      "properties": {
        "namespace": { "enum": ["storage", "actionId", "uniqueId", "itemId"] },
        "value": { "type": "integer" },
        "sources": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/source" }
        },
        "severity": { "enum": ["info", "warning", "error"] },
        "reason": { "type": "string" }
      },
      "additionalProperties": false
    },
    "reservation": {
      "type": "object",
      "required": ["taskId", "namespace", "from", "to", "status"],
      "properties": {
        "taskId": { "type": "string" },
        "namespace": { "enum": ["storage", "actionId", "uniqueId", "itemId"] },
        "from": { "type": "integer", "minimum": 0 },
        "to": { "type": "integer", "minimum": 0 },
        "status": { "enum": ["reserved", "committed", "released"] },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    },
    "binarySource": {
      "type": "object",
      "required": ["path", "sha256", "fileSize", "version", "itemsMajor", "itemsMinor", "tileCount", "topLevelItemCount", "counts"],
      "properties": {
        "path": { "type": "string" },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "fileSize": { "type": "integer", "minimum": 1 },
        "version": { "type": "integer", "minimum": 1 },
        "itemsMajor": { "type": "integer", "minimum": 1 },
        "itemsMinor": { "type": "integer", "minimum": 0 },
        "tileCount": { "type": "integer", "minimum": 0 },
        "topLevelItemCount": { "type": "integer", "minimum": 0 },
        "counts": {
          "type": "object",
          "required": ["actionId", "uniqueId"],
          "properties": {
            "actionId": { "type": "integer", "minimum": 0 },
            "uniqueId": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
