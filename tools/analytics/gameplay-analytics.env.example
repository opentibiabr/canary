# Example environment file for Gameplay Analytics installation and migration tooling.
#
# Copy this file to a secured location such as /etc/canary/gameplay-analytics.env,
# restrict its permissions (chmod 600), and fill in real values there.
# Never commit a filled-in copy of this file to version control.

# Database connection used by install_gameplay_analytics.sh, migrate_gameplay_analytics.sh
# and maintain_gameplay_analytics.sh.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=canary
DB_PASSWORD=CHANGE_ME
DB_NAME=canary

# Stable build or balance-patch identifier persisted on analytics_sessions.server_version.
# Export this alongside starting the Canary process, for example through a systemd
# EnvironmentFile=, so the running server and the tooling agree on the same value.
CANARY_SERVER_VERSION=CHANGE_ME
